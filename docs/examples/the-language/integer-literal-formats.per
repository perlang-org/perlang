// integer-literal-formats.per
var year_of_quake = 1996;
var vga_framebuffer = 0xA0000;
var file_mode = 0o755;
var high_nibble_set = 0b11110000;
var one_megabyte = 1_048_576;

print year_of_quake;
print vga_framebuffer;
print file_mode;
print high_nibble_set;
print one_megabyte;

// Expected output:
// 1996
// 655360
// 493
// 240
// 1048576
